#!/bin/bash
# =============================================================================
# create_users.sh — Automatiserat script för användarskapande
# Kurs: Linux & Bash | Student: DZ3ZF8BP
#
# Användning: sudo ./create_users.sh <användare1> <användare2> ...
# Exempel:    sudo ./create_users.sh Anna Bjorn Charlie
#
# Scriptet:
#   1. Kontrollerar att det körs som root
#   2. Skapar varje användare med useradd
#   3. Skapar mapparna Documents, Downloads och Work i hemkatalogen
#   4. Sätter rättigheter så att endast ägaren kan läsa/skriva (700)
#   5. Skapar en personlig welcome.txt med välkomstmeddelande och användarlista
# =============================================================================

# ---------------------------------------------------------------------------
# 1. BEHÖRIGHETSKONTROLL — Endast root (UID 0) får köra scriptet
# ---------------------------------------------------------------------------
if [ "$EUID" -ne 0 ]; then
    echo "Fel: Det här scriptet måste köras som root."
    echo "Försök igen med: sudo $0 $*"
    exit 1
fi

# ---------------------------------------------------------------------------
# 2. KONTROLLERA ATT MINST ETT ARGUMENT SKICKADES IN
# ---------------------------------------------------------------------------
if [ $# -eq 0 ]; then
    echo "Fel: Inga användarnamn angavs."
    echo "Användning: sudo $0 <användare1> <användare2> ..."
    exit 1
fi

# ---------------------------------------------------------------------------
# 3. LOOPA IGENOM VARJE ANVÄNDARNAMN SOM ARGUMENT
# ---------------------------------------------------------------------------
for username in "$@"; do

    echo "-------------------------------------------"
    echo "Bearbetar användare: $username"

    # Kontrollera om användaren redan finns
    if id "$username" &>/dev/null; then
        echo "Varning: Användaren '$username' finns redan — hoppar över."
        continue
    fi

    # -------------------------------------------------------------------------
    # Skapa användaren med hemkatalog och bash som standardskal
    # -------------------------------------------------------------------------
    useradd -m -s /bin/bash "$username"

    if [ $? -ne 0 ]; then
        echo "Fel: Kunde inte skapa användaren '$username'."
        continue
    fi

    echo "Användare '$username' skapades."

    # Hämta sökvägen till användarens hemkatalog
    home_dir=$(getent passwd "$username" | cut -d: -f6)

    # -------------------------------------------------------------------------
    # Skapa undermapparna Documents, Downloads och Work
    # -------------------------------------------------------------------------
    for dir in Documents Downloads Work; do
        mkdir -p "${home_dir}/${dir}"
        echo "  Skapade mapp: ${home_dir}/${dir}"
    done

    # -------------------------------------------------------------------------
    # Sätt rättigheter: endast ägaren kan läsa och skriva (chmod 700)
    # Gäller hemkatalogen och alla undermappar
    # -------------------------------------------------------------------------
    chown -R "${username}:${username}" "$home_dir"
    chmod 700 "${home_dir}/Documents"
    chmod 700 "${home_dir}/Downloads"
    chmod 700 "${home_dir}/Work"

    echo "  Rättigheter satta (700) för Documents, Downloads, Work."

    # -------------------------------------------------------------------------
    # Skapa welcome.txt med personligt välkomstmeddelande och användarlista
    # -------------------------------------------------------------------------
    welcome_file="${home_dir}/welcome.txt"

    # Rad 1: Personligt välkomstmeddelande
    echo "Välkommen $username" > "$welcome_file"

    # Rad 2: Tomrad för läsbarhet
    echo "" >> "$welcome_file"

    # Lista alla andra användare som redan finns i systemet (UID >= 1000)
    # exklusive den nyss skapade användaren
    echo "Andra användare i systemet:" >> "$welcome_file"

    while IFS=: read -r name _ uid _; do
        # Visa bara vanliga användare (UID >= 1000) som INTE är den nye användaren
        if [ "$uid" -ge 1000 ] && [ "$name" != "$username" ]; then
            echo "  - $name" >> "$welcome_file"
        fi
    done < /etc/passwd

    # Sätt rätt ägarskap på welcome.txt
    chown "${username}:${username}" "$welcome_file"
    chmod 640 "$welcome_file"

    echo "  Skapade: ${welcome_file}"
    echo "Klar med användare '$username'."

done

echo "-------------------------------------------"
echo "Alla användare har bearbetats."
exit 0
